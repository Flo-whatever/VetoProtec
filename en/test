  <style>
    .hero { padding: 72px 0 28px; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 24px;
      align-items: stretch;
    }

    .hero-card {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100%;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent2);
      background: rgba(255,255,255,.65);
      width: fit-content;
    }

    .h-title {
      font-family: 'DM Serif Display', serif;
      font-size: 50px;
      line-height: 1.03;
      margin: 0 0 18px;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, var(--text) 45%, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .h-sub {
      color: var(--muted);
      font-size: 17px;
      margin: 0 0 24px;
      max-width: 60ch;
      font-weight: 300;
      line-height: 1.7;
    }

    .cta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .hero-note {
      margin-top: 20px;
      font-size: 14px;
      color: var(--muted);
      font-weight: 400;
      line-height: 1.6;
    }

    .mini-proof {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 24px;
    }

    .mini-proof .proof-item {
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 14px;
      background: rgba(255,255,255,.5);
    }

    .mini-proof .proof-item strong {
      display: block;
      font-size: 14px;
      margin-bottom: 4px;
      color: var(--text);
    }

    .mini-proof .proof-item span {
      display: block;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
      font-weight: 300;
    }

    .product {
      position: relative;
      overflow: hidden;
    }

    .product h3 {
      margin: 0 0 8px;
      font-family: 'DM Serif Display', serif;
      font-size: 24px;
      font-weight: 400;
      position: relative;
      z-index: 1;
    }

    .product .product-kicker {
      display: inline-block;
      margin-bottom: 10px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--accent2);
    }

    .product ul {
      margin: 12px 0 0;
      padding-left: 18px;
      color: var(--muted);
      font-weight: 300;
      position: relative;
      z-index: 1;
    }

    .product li {
      margin: 8px 0;
      line-height: 1.5;
    }

    .product > p,
    .product .cta {
      position: relative;
      z-index: 1;
    }

    .product-bg {
      position: absolute;
      bottom: -20px;
      right: -20px;
      width: 80%;
      max-width: 340px;
      height: 105%;
      object-fit: contain;
      opacity: 0.08;
      pointer-events: none;
      filter: grayscale(20%);
      transition: opacity 0.3s ease;
    }

    .card.product:hover .product-bg { opacity: 0.14; }

    .carousel-wrap {
      border: 1px solid var(--border);
      border-radius: 22px;
      overflow: hidden;
      position: relative;
      height: 420px;
      box-shadow: 0 8px 30px rgba(192,132,200,.14);
      background: linear-gradient(140deg, #fcf7fb, #f8f4ff);
    }

    .carousel-track {
      display: flex;
      height: 100%;
      transition: transform .45s cubic-bezier(.4,0,.2,1);
    }

    .carousel-slide {
      position: relative;
      min-width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 10px;
      font-weight: 600;
      font-size: 15px;
      color: var(--muted);
      text-align: center;
      overflow: hidden;
      padding: 20px;
    }

    .carousel-slide:nth-child(1) { background: linear-gradient(140deg, #fce7f3, #e9d5ff); }
    .carousel-slide:nth-child(2) { background: linear-gradient(140deg, #f5e6d8, #fce7f3); }
    .carousel-slide:nth-child(3) { background: linear-gradient(140deg, #e9d5ff, #f5e6d8); }
    .carousel-slide:nth-child(4) { background: linear-gradient(140deg, #fce7f3, #f5e6d8); }
    .carousel-slide:nth-child(5) { background: linear-gradient(140deg, #e9d5ff, #fce7f3); }

    .carousel-slide img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .carousel-label {
      position: absolute;
      bottom: 20px;
      left: 20px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      background: rgba(255,255,255,.85);
      color: var(--text);
      box-shadow: 0 4px 16px rgba(0,0,0,.08);
    }

    .carousel-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: none;
      cursor: pointer;
      background: rgba(255,255,255,.88);
      backdrop-filter: blur(6px);
      box-shadow: 0 2px 12px rgba(192,132,200,.3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: var(--text);
      transition: background .15s, transform .15s;
      z-index: 2;
    }

    .carousel-btn:hover {
      background: #fff;
      transform: translateY(-50%) scale(1.08);
    }

    .carousel-btn.prev { left: 12px; }
    .carousel-btn.next { right: 12px; }

    .carousel-dots {
      position: absolute;
      bottom: 14px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 7px;
      z-index: 2;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(192,132,200,.35);
      border: none;
      cursor: pointer;
      padding: 0;
      transition: background .2s, transform .2s;
    }

    .dot.active {
      background: var(--accent2);
      transform: scale(1.35);
    }

    .section-soft {
      padding-top: 6px;
    }

    .section-split {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .point-card {
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 20px;
      background: rgba(255,255,255,.5);
    }

    .point-card h3 {
      margin: 0 0 8px;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
    }

    .point-card p {
      margin: 0;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.6;
    }

    .order-box {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 20px;
    }

    .order-step {
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 18px;
      background: rgba(255,255,255,.45);
    }

    .order-step .num {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      margin-bottom: 10px;
      background: rgba(192,132,200,.16);
      color: var(--accent2);
    }

    .order-step h3 {
      margin: 0 0 8px;
      font-size: 17px;
      font-weight: 600;
    }

    .order-step p {
      margin: 0;
      color: var(--muted);
      font-weight: 300;
      line-height: 1.6;
    }

    header .nav {
      height: auto;
      padding: 14px 0;
    }

    .brand {
      font-weight: 700;
      font-family: 'DM Serif Display', serif;
      font-size: 18px;
      letter-spacing: .01em;
      color: inherit;
    }

    .brand img { height: 80px; }

    .cart-icon-btn {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--bg);
      cursor: pointer;
      text-decoration: none;
      font-size: 18px;
      transition: background .15s;
    }

    .cart-icon-btn:hover { background: var(--border); }

    .cart-badge {
      position: absolute;
      top: -4px;
      right: -4px;
      background: #e11d48;
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: none;
      align-items: center;
      justify-content: center;
    }

    .cart-badge.visible { display: flex; }

    .founder-wrap {
      display: flex;
      align-items: center;
      gap: 18px;
      margin: 20px 0 24px;
    }

    .founder-photo {
      width: 78px;
      height: 78px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    .founder-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      transform: scale(1.25);
      transform-origin: center center;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .section-split,
      .order-box,
      .mini-proof {
        grid-template-columns: 1fr;
      }

      .h-title { font-size: 38px; }
      .carousel-wrap { height: 300px; }
      .founder-wrap {
        align-items: flex-start;
      }
    }

    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
