<script>
  document.getElementById("y").textContent = new Date().getFullYear();

  // Cart badge
  function updateCartBadge() {
    try {
      const cart = JSON.parse(sessionStorage.getItem('vp_cart') || '{}');
      const count = Object.values(cart).reduce((a, b) => a + b, 0);
      const badge = document.getElementById('cartBadge');
      if (count > 0) {
        badge.textContent = count;
        badge.classList.add('visible');
      } else {
        badge.classList.remove('visible');
      }
    } catch {}
  }
  updateCartBadge();

  // Carousel
  const track = document.getElementById("carouselTrack");
  const slides = track.querySelectorAll(".carousel-slide");
  const dotsEl = document.getElementById("carouselDots");
  const total = slides.length;
  let current = 0, timer;

  slides.forEach((_, i) => {
    const dot = document.createElement("button");
    dot.className = "dot" + (i === 0 ? " active" : "");
    dot.setAttribute("aria-label", "Image " + (i + 1));
    dot.addEventListener("click", () => goTo(i));
    dotsEl.appendChild(dot);
  });

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dotsEl.querySelectorAll(".dot").forEach((d, i) => d.classList.toggle("active", i === current));
    resetTimer();
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), 4000);
  }

  document.getElementById("prevBtn").addEventListener("click", () => goTo(current - 1));
  document.getElementById("nextBtn").addEventListener("click", () => goTo(current + 1));

  const carousel = document.getElementById("carousel");
  carousel.addEventListener("mouseenter", () => clearInterval(timer));
  carousel.addEventListener("mouseleave", resetTimer);

  let startX = 0;
  carousel.addEventListener("touchstart", e => { startX = e.touches[0].clientX; });
  carousel.addEventListener("touchend", e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
  });

  resetTimer();

  // Contact form
  document.getElementById("contactForm").addEventListener("submit", async function(e) {
    e.preventDefault();

    const btn = document.getElementById("submitBtn");
    const feedback = document.getElementById("formFeedback");
    const nom = document.getElementById("nom").value.trim();
    const email = document.getElementById("email").value.trim();
    const message = document.getElementById("message").value.trim();

    btn.textContent = "Sending…";
    btn.disabled = true;
    feedback.style.display = "none";

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nom, email, message }),
      });

      const data = await res.json();

      if (res.ok) {
        feedback.textContent = "✅ Message sent! We'll get back to you soon.";
        feedback.style.cssText = "background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;display:block;margin-top:14px;padding:12px 16px;border-radius:14px;font-size:14px;font-weight:500";
        document.getElementById("contactForm").reset();
      } else {
        throw new Error(data.error || "Unknown error");
      }
    } catch (err) {
      feedback.textContent = "❌ " + (err.message || "Something went wrong. Please try again.");
      feedback.style.cssText = "background:#fef2f2;color:#991b1b;border:1px solid #fecaca;display:block;margin-top:14px;padding:12px 16px;border-radius:14px;font-size:14px;font-weight:500";
    } finally {
      btn.textContent = "Send message";
      btn.disabled = false;
    }
  });
</script>

