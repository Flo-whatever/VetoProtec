            </div>
          </div>

          <div style="margin-top:14px">
            <label>Message<br/>
              <textarea id="message" rows="5" placeholder="Tell us which product you need, your country and the quantity required…" required></textarea>
            </label>
          </div>

          <div id="formFeedback" style="display:none;margin-top:14px;padding:12px 16px;border-radius:14px;font-size:14px;font-weight:500"></div>

          <div class="cta">
            <button class="btn primary" type="submit" id="submitBtn">Send message</button>
            <a class="btn" href="https://www.instagram.com/veto.protec/">Instagram</a>
            <a class="btn" href="https://www.linkedin.com/company/veto-protec">LinkedIn</a>
            <a class="btn" href="https://www.facebook.com/people/Veto-Protec/61567468355158/">Facebook</a>
